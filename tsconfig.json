{
  "compilerOptions": {
    "target": "ESNext",                     /* Versão do JavaScript */
    "module": "NodeNext",                   /* Sistema de módulos do Node */
    "moduleResolution": "NodeNext",         /* Como o TS vai procurar os arquivos nas pastas */
    "esModuleInterop": true,                /* Garante retrocompatibilidade entre pacotes*/
    "strict": true,                         /* Ativa as verificações*/
    "skipLibCheck": true,                   /* Ignora checagem de tipos dentro de node_modules */
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
},
    "include": [
     "src/**/*",
     "prisma/prisma.config.ts"
     ]                                      /* Diz ao TS para monitorar os diretorios*/
}